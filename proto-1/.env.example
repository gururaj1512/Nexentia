# Runtime mode
NODE_ENV=development

# Proxy service (index.js)
PORT=3000
PROXY_PORT=3000
BACKEND_URL=http://localhost:4001
PROXY_TARGET_V1=http://localhost:4001
PROXY_TARGET_V2=http://localhost:4002
PROXY_TARGET_PUBLIC=http://localhost:4001
MAIN_BACKEND_URL=http://localhost:4001

# Production safety controls
ALLOW_LOCAL_TARGETS=false
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb

# Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-24-characters
JWT_EXPIRES_IN=44h
BCRYPT_SALT_ROUNDS=10

# Database
DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
SKIP_DB_INIT=false

# Optional AI analyzer
GEMINI_API_KEY=

# Mock backend service (mock-backend.js)
HOST=0.0.0.0
PROXY_BASE_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:4001
